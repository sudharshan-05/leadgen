# ============================================================
# Lead Intelligence Agent - .gitignore
# ============================================================

# ---- SECRETS (NEVER commit these) ----
.env
*.pem
*.key

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
.Python
.venv/
venv/
env/
ENV/
pip-log.txt
pip-delete-this-directory.txt

# ---- Generated outputs (large files, not needed in repo) ----
exports/
outputs/
output/
*.xlsx
*.xls
*.csv

# ---- Databases ----
*.db
*.sqlite
*.sqlite3

# ---- Logs ----
logs/
*.log

# ---- Database backups ----
database_backup/

# ---- OS / IDE ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ---- Scratch / temp ----
scratch/

# ---- Docker artifacts ----
.docker/

# ---- Gemini/AI agent internals ----
.gemini/
.agents/
