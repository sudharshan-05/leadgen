# ================================================================
# Lead Intelligence Platform - Production Environment Config
# ================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to GitHub - it contains secrets!

# Application Mode
ENV=production

# ==== REQUIRED ====
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_token_here

# ==== DATABASE ====
# For Railway/Render free tier PostgreSQL, copy the connection string from their dashboard:
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:postgres@db:5432/lead_agent

# ==== REDIS ====
# For Railway/Render free tier Redis:
REDIS_URL=redis://redis:6379/0

# ==== OPTIONAL ====
# Sentry for error monitoring (free tier available at sentry.io)
SENTRY_DSN=

# Google Maps API key (optional, scraper works without it too)
GOOGLE_MAPS_API_KEY=
